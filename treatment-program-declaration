<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wellness Program Form</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            color: #333;
            line-height: 1.6;
            padding: 20px;
        }
        .container {
            max-width: 800px;
            margin: 0 auto;
            background: #fff;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }
        h1 {
            text-align: center;
            color: #2c3e50;
            margin-bottom: 5px;
            font-style: italic;
        }
        .intro-text {
            text-align: center;
            color: #666;
            margin-bottom: 30px;
            font-size: 0.95em;
        }
        .form-group {
            margin-bottom: 25px;
        }
        .form-row {
            display: flex;
            gap: 20px;
            margin-bottom: 25px;
        }
        .form-row .form-group {
            margin-bottom: 0;
            flex: 1;
        }
        label {
            display: block;
            font-weight: 600;
            margin-bottom: 8px;
            color: #2c3e50;
            font-size: 0.9em;
        }
        input[type="text"],
        input[type="number"],
        textarea {
            width: 100%;
            padding: 10px;
            border: 1px solid #ccc;
            border-radius: 4px;
            font-family: inherit;
            box-sizing: border-box;
        }
        input[type="text"]:focus,
        input[type="number"]:focus,
        textarea:focus {
            border-color: #3498db;
            outline: none;
            box-shadow: 0 0 5px rgba(52, 152, 219, 0.3);
        }
        textarea {
            resize: vertical;
            height: 60px;
        }
        .session-group {
            display: flex;
            align-items: center;
            gap: 15px;
            margin-top: 10px;
        }
        .session-box {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            border: 1px solid #333;
            cursor: pointer;
            position: relative;
        }
        .session-box input {
            position: absolute;
            opacity: 0;
            cursor: pointer;
            height: 0;
            width: 0;
        }
        .session-box span {
            font-weight: bold;
            font-size: 1.2em;
        }
        .session-box input:checked ~ span {
            text-decoration: underline;
            color: #e74c3c;
        }
        
        /* Signature Styles */
        .signature-section {
            display: flex;
            gap: 30px;
            margin-top: 40px;
            border-top: 2px dashed #ccc;
            padding-top: 30px;
        }
        .signature-box {
            flex: 1;
        }
        canvas {
            border: 1px solid #aaa;
            border-radius: 4px;
            background-color: #fafafa;
            cursor: crosshair;
            width: 100%;
            height: 150px;
        }
        .btn-clear {
            display: block;
            margin-top: 5px;
            background: #e74c3c;
            color: white;
            border: none;
            padding: 5px 10px;
            border-radius: 3px;
            cursor: pointer;
            font-size: 0.8em;
        }
        .btn-clear:hover {
            background: #c0392b;
        }
        .submit-btn {
            display: block;
            width: 100%;
            padding: 15px;
            background: #2c3e50;
            color: white;
            font-size: 1.1em;
            border: none;
            border-radius: 4px;
            margin-top: 40px;
            cursor: pointer;
            font-weight: bold;
        }
        .submit-btn:hover {
            background: #1a252f;
        }

        @media (max-width: 600px) {
            .form-row, .signature-section {
                flex-direction: column;
            }
        }
    </style>
</head>
<body>

<div class="container">
    <h1>Wellness Program</h1>
    <p class="intro-text">To get started, we'd love to know a little more about you. Please share some details.</p>

    <form action="#" method="POST" id="wellnessForm">
        
        <div class="form-row">
            <div class="form-group" style="flex: 3;">
                <label for="fullName">Full Name</label>
                <input type="text" id="fullName" name="fullName" required>
            </div>
            <div class="form-group" style="flex: 1;">
                <label for="age">Age</label>
                <input type="number" id="age" name="age" required>
            </div>
        </div>

        <div class="form-group">
            <label for="injuries">Have you experienced any physical injuries or undergone any surgeries recently?</label>
            <textarea id="injuries" name="injuries" placeholder="please specify:"></textarea>
        </div>

        <div class="form-group">
            <label for="pressure">What type of pressure do you prefer while taking a massage?</label>
            <input type="text" id="pressure" name="pressure" placeholder="please specify:">
        </div>

        <div class="form-group">
            <label for="medicalCondition">Do you have any skin or medical condition?</label>
            <textarea id="medicalCondition" name="medicalCondition" placeholder="please specify:"></textarea>
        </div>

        <div class="form-group">
            <label for="exercise">How often do you exercise, and do you participate in any sports regularly?</label>
            <textarea id="exercise" name="exercise" placeholder="please specify:"></textarea>
        </div>

        <div class="form-group">
            <label for="sleep">How would you describe your sleep pattern? Do you wake up feeling refreshed or tired?</label>
            <textarea id="sleep" name="sleep" placeholder="please specify:"></textarea>
        </div>

        <div class="form-group">
            <label for="chronicPain">Is there any particular area where you experience chronic pain?</label>
            <textarea id="chronicPain" name="chronicPain" placeholder="please specify:"></textarea>
        </div>

        <div class="form-group">
            <label for="goal">What is your main goal in booking this treatment package?</label>
            <textarea id="goal" name="goal" placeholder="please specify:"></textarea>
        </div>

        <div class="form-group">
            <label>Session Completed</label>
            <div class="session-group">
                <label class="session-box"><input type="checkbox" name="session1"><span>1</span></label>
                <label class="session-box"><input type="checkbox" name="session2"><span>2</span></label>
                <label class="session-box"><input type="checkbox" name="session3"><span>3</span></label>
                <label class="session-box"><input type="checkbox" name="session4"><span>4</span></label>
                <label class="session-box"><input type="checkbox" name="session5"><span>5</span></label>
            </div>
        </div>

        <div class="signature-section">
            <div class="signature-box">
                <label>Customer Signature</label>
                <canvas id="customerCanvas"></canvas>
                <button type="button" class="btn-clear" onclick="clearCanvas('customerCanvas')">Clear Signature</button>
            </div>
            
            <div class="signature-box">
                <label>Worker Signature</label>
                <canvas id="workerCanvas"></canvas>
                <button type="button" class="btn-clear" onclick="clearCanvas('workerCanvas')">Clear Signature</button>
            </div>
        </div>

        <button type="submit" class="submit-btn">Save Form</button>

    </form>
</div>

<script>
    // Function to set up drawing functionality for a canvas
    function setupCanvas(canvasId) {
        const canvas = document.getElementById(canvasId);
        const ctx = canvas.getContext('2d');
        let isDrawing = false;

        // Resize canvas to fit container properly
        function resizeCanvas() {
            const rect = canvas.parentElement.getBoundingClientRect();
            canvas.width = rect.width;
            canvas.height = 150; 
        }
        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        // Drawing Event Listeners (Mouse)
        canvas.addEventListener('mousedown', startDrawing);
        canvas.addEventListener('mousemove', draw);
        canvas.addEventListener('mouseup', stopDrawing);
        canvas.addEventListener('mouseout', stopDrawing);

        // Drawing Event Listeners (Touch for mobile devices)
        canvas.addEventListener('touchstart', startDrawingTouch, { passive: false });
        canvas.addEventListener('touchmove', drawTouch, { passive: false });
        canvas.addEventListener('touchend', stopDrawing);

        function startDrawing(e) {
            isDrawing = true;
            draw(e);
        }

        function startDrawingTouch(e) {
            e.preventDefault();
            isDrawing = true;
            drawTouch(e);
        }

        function draw(e) {
            if (!isDrawing) return;
            ctx.lineWidth = 2;
            ctx.lineCap = 'round';
            ctx.strokeStyle = '#000';

            const rect = canvas.getBoundingClientRect();
            ctx.lineTo(e.clientX - rect.left, e.clientY - rect.top);
            ctx.stroke();
            ctx.beginPath();
            ctx.moveTo(e.clientX - rect.left, e.clientY - rect.top);
        }

        function drawTouch(e) {
            if (!isDrawing) return;
            e.preventDefault();
            ctx.lineWidth = 2;
            ctx.lineCap = 'round';
            ctx.strokeStyle = '#000';

            const rect = canvas.getBoundingClientRect();
            const touch = e.touches[0];
            ctx.lineTo(touch.clientX - rect.left, touch.clientY - rect.top);
            ctx.stroke();
            ctx.beginPath();
            ctx.moveTo(touch.clientX - rect.left, touch.clientY - rect.top);
        }

        function stopDrawing() {
            isDrawing = false;
            ctx.beginPath();
        }
    }

    // Function to clear a specific canvas
    function clearCanvas(canvasId) {
        const canvas = document.getElementById(canvasId);
        const ctx = canvas.getContext('2d');
        ctx.clearRect(0, 0, canvas.width, canvas.height);
    }

    // Initialize both canvases
    window.onload = () => {
        setupCanvas('customerCanvas');
        setupCanvas('workerCanvas');
    };
</script>

</body>
</html>
